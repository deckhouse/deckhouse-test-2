{{ define "fuzz corpus sync" }}
- |
  echo "Download fuzz corpus overlay from S3"

  apk add --no-cache curl ca-certificates

  MC=/tmp/mc
  curl -fsSL -o "${MC}" https://dl.min.io/client/mc/release/linux-amd64/mc
  chmod +x "${MC}"

  "${MC}" alias set fuzz-s3 \
    "$(cat /run/secrets/FUZZ_S3_ENDPOINT)" \
    "$(cat /run/secrets/FUZZ_S3_ACCESS_KEY)" \
    "$(cat /run/secrets/FUZZ_S3_SECRET_KEY)"

  mkdir -p /src

  CORPUS_PATH="fuzz-s3/anomaloys-materials/corpus/"

  if "${MC}" ls "${CORPUS_PATH}" 2>/dev/null | grep -q .; then
    echo "Fuzz corpus found in S3, download overlay"

    if ! "${MC}" mirror "${CORPUS_PATH}" "/src/"; then
      echo "Failed to download fuzz corpus overlay, skip it"
    fi
  else
    echo "No fuzz corpus found in S3 yet, skip download"
  fi
{{ end }}
